@model UniSync.Web.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Academic Hub";
    Layout = "_AdminLayout";
}

<div class="space-y-10 pb-20 animate-fade-in-up">
    <!-- Header Protocol -->
    <header class="glass-panel p-10 lg:p-12 rounded-[3.5rem] relative overflow-hidden group">
        <div class="absolute -right-20 -top-20 w-96 h-96 bg-emerald-400/20 rounded-full blur-[120px] group-hover:bg-emerald-400/30 transition-all duration-700"></div>
        <div class="absolute -left-20 -bottom-20 w-80 h-80 bg-blue-400/10 rounded-full blur-[100px] group-hover:bg-blue-400/20 transition-all duration-700"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-emerald-600 mb-2">Module Authority</p>
                <h1 class="text-4xl md:text-5xl font-black text-slate-900 font-headline leading-tight tracking-tight">
                    Academic <span class="text-emerald-600">Hub</span>
                </h1>
                <p class="text-lg font-medium text-slate-500 max-w-2xl mt-4">
                    Orchestrate research allocations, monitor student progress, and manage academic taxonomy.
                </p>
            </div>
            <div class="hidden md:flex gap-3">
                <span class="px-4 py-2 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-[10px] font-black uppercase tracking-widest text-emerald-600 shadow-sm flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    Module Leader
                </span>
            </div>
        </div>
    </header>

    <!-- System Telemetry Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Intake Metric -->
        <div class="glass-card p-8 rounded-[2rem] relative overflow-hidden hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-900/10 transition-all duration-300 group shadow-md backdrop-blur-xl border border-slate-700/50 bg-slate-900/40">
            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-emerald-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-all"></div>
            <span class="material-symbols-outlined absolute right-6 top-6 text-emerald-500 opacity-20 text-4xl group-hover:scale-110 transition-transform">menu_book</span>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Academic Intake</p>
            <p class="text-4xl font-black text-white font-headline mb-1">@Model.SubmissionLoadPercent<span class="text-xl text-emerald-500">%</span></p>
            <p class="text-[11px] font-bold text-slate-500 mt-2">@Model.ActiveSubmissions Pending Reviews</p>
        </div>

        <!-- Allocation Metric -->
        <div class="glass-card p-8 rounded-[2rem] relative overflow-hidden hover:-translate-y-2 hover:shadow-2xl hover:shadow-blue-900/10 transition-all duration-300 group shadow-md backdrop-blur-xl border border-slate-700/50 bg-slate-900/40">
            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/20 transition-all"></div>
            <span class="material-symbols-outlined absolute right-6 top-6 text-blue-500 opacity-20 text-4xl group-hover:scale-110 transition-transform">handshake</span>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Allocation Rate</p>
            <p class="text-4xl font-black text-white font-headline mb-1">@Model.LinkRatePercent<span class="text-xl text-blue-500">%</span></p>
            <p class="text-[11px] font-bold text-slate-500 mt-2">@Model.SuccessfulLinks Secured Links</p>
        </div>

        <!-- Student Metric -->
        <div class="glass-card p-8 rounded-[2rem] relative overflow-hidden hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-900/10 transition-all duration-300 group shadow-md backdrop-blur-xl border border-slate-700/50 bg-slate-900/40">
            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/20 transition-all"></div>
            <span class="material-symbols-outlined absolute right-6 top-6 text-purple-500 opacity-20 text-4xl group-hover:scale-110 transition-transform">school</span>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Student Body</p>
            <p class="text-4xl font-black text-white font-headline mb-1">@Model.TotalStudents</p>
            <p class="text-[11px] font-bold text-slate-500 mt-2">Active Research Candidates</p>
        </div>

        <!-- Review Queue Metric -->
        <div class="glass-card p-8 rounded-[2rem] relative overflow-hidden hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-900/10 transition-all duration-300 group shadow-md backdrop-blur-xl border border-slate-700/50 bg-slate-900/40">
            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-emerald-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-all"></div>
            <span class="material-symbols-outlined absolute right-6 top-6 text-emerald-500 opacity-20 text-4xl group-hover:scale-110 transition-transform">assignment_ind</span>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Review Queue</p>
            <p class="text-4xl font-black text-white font-headline mb-1">@Model.RecentSubmissions.Count</p>
            <p class="text-[11px] font-bold text-slate-500 mt-2">Latest Actionable Projects</p>
        </div>
    </div>

    <!-- Analytics Architecture -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Activity Graph -->
        <div class="lg:col-span-2 glass-panel p-8 md:p-10 rounded-[3.5rem] flex flex-col h-[480px] bg-white border border-slate-100 shadow-xl">
            <div class="flex justify-between items-start mb-10">
                <div>
                    <h3 class="text-2xl font-black text-slate-900 font-headline">Submission Trends</h3>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mt-1">Proposal Intake Velocity</p>
                </div>
                <div class="bg-slate-100 p-1.5 rounded-2xl flex gap-1">
                    <button id="btn-realtime" class="px-5 py-2 text-[10px] font-black uppercase tracking-widest bg-slate-900 text-white shadow-lg rounded-xl transition-all">Realtime</button>
                    <button id="btn-history" class="px-5 py-2 text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-slate-900 transition-all rounded-xl">History</button>
                </div>
            </div>
            <div class="flex-1 relative">
                <canvas id="activityChart"></canvas>
            </div>
        </div>

        <!-- Recent Activity Panel -->
        <div class="glass-card p-8 md:p-10 rounded-[3.5rem] flex flex-col h-[480px] bg-slate-900 border border-slate-800 shadow-2xl relative overflow-hidden">
            <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-emerald-500/5 rounded-full blur-3xl"></div>
            <h3 class="text-xl font-black text-white font-headline mb-8 flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                Action Required
            </h3>
            <div class="space-y-4 flex-1 overflow-y-auto pr-2 custom-scrollbar">
                @if (!Model.RecentSubmissions.Any())
                {
                    <div class="flex flex-col items-center justify-center h-full text-center space-y-4 opacity-40">
                        <span class="material-symbols-outlined text-4xl text-slate-500">space_dashboard</span>
                        <p class="text-[10px] font-black uppercase tracking-widest text-slate-500">Queue Clear</p>
                    </div>
                }
                @foreach (var sub in Model.RecentSubmissions)
                {
                    <div class="p-5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all group">
                        <div class="flex justify-between items-start mb-2">
                            <span class="px-2 py-0.5 rounded-md bg-emerald-500/20 text-emerald-400 text-[8px] font-black uppercase tracking-tighter">New Proposal</span>
                            <span class="text-[9px] text-slate-500 font-bold">@sub.SubmissionDate.ToString("HH:mm")</span>
                        </div>
                        <p class="text-[11px] text-slate-200 font-bold leading-tight group-hover:text-emerald-400 transition-colors">@sub.Title</p>
                        <p class="text-[9px] text-slate-500 mt-2 font-medium">By: @(sub.Submitter?.FullName ?? "Unknown Student")</p>
                    </div>
                }
            </div>
            <a href="@Url.Action("AllocationOversight", "ModuleLeader")" class="mt-8 w-full py-4 rounded-2xl bg-emerald-500 text-slate-950 font-black text-[11px] text-center uppercase tracking-widest hover:bg-emerald-400 transition-all shadow-xl shadow-emerald-500/20 active:scale-95">
                Manage Allocations
            </a>
        </div>
    </div>

    <!-- Phase 2: Analytics Row -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-10">
        <!-- Heatmap Card -->
        <div class="lg:col-span-2 glass-panel p-10 rounded-[3.5rem] bg-white shadow-xl relative overflow-hidden group border border-slate-100 flex flex-col h-[480px]">
            <div class="flex items-center justify-between mb-10">
                <div>
                    <h3 class="text-2xl font-black text-slate-900 font-headline">Expertise Heatmap</h3>
                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mt-1">Resource Saturation Analysis</p>
                </div>
                <div class="flex gap-4">
                    <span class="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase tracking-widest">
                        <span class="w-3 h-3 rounded-full bg-blue-500"></span> Students
                    </span>
                    <span class="flex items-center gap-2 text-[10px] font-black text-slate-400 uppercase tracking-widest">
                        <span class="w-3 h-3 rounded-full bg-emerald-500"></span> Supervisors
                    </span>
                </div>
            </div>
            <div class="flex-1 relative">
                <canvas id="heatmapChart"></canvas>
            </div>
        </div>

        <!-- Performance Card -->
        <div class="lg:col-span-1 glass-panel p-10 rounded-[3.5rem] bg-slate-900 text-white shadow-2xl relative overflow-hidden group border border-slate-700/50 flex flex-col h-[480px]">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-emerald-500/10 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-700"></div>
            
            <h3 class="text-xl font-black font-headline mb-2">Academic Response</h3>
            <p class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-10">Supervisor Latency Stats</p>

            <div class="space-y-8 relative z-10 flex-1 flex flex-col justify-center">
                <div class="text-center p-8 rounded-[2.5rem] bg-emerald-500/10 border border-emerald-500/20 shadow-inner">
                    <p class="text-6xl font-black text-emerald-400 font-headline mb-2">@ViewBag.AvgLatency<span class="text-lg text-emerald-600/50 ml-1 italic">d</span></p>
                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-emerald-600">Avg Lead Time</p>
                </div>
                
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-[11px] font-black uppercase text-slate-500 tracking-widest">Efficiency Status</span>
                        <span class="px-3 py-1 bg-emerald-500/10 text-emerald-400 text-[9px] font-black rounded-lg uppercase tracking-widest border border-emerald-500/20">Optimal Range</span>
                    </div>
                    <div class="w-full bg-slate-800 h-2.5 rounded-full overflow-hidden">
                        <div class="bg-emerald-500 h-full w-[85%] rounded-full shadow-[0_0_15px_rgba(16,185,129,0.6)]"></div>
                    </div>
                </div>
            </div>
            
            <div class="mt-8 pt-8 border-t border-slate-800">
                <p class="text-[11px] text-slate-500 font-medium leading-relaxed italic">
                    <span class="text-emerald-500 font-black mr-1">NOTE:</span> Based on UTC timestamps of proposal lifecycle events.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const ctx = document.getElementById('activityChart').getContext('2d');
            const gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(16, 185, 129, 0.2)');
            gradient.addColorStop(1, 'rgba(16, 185, 129, 0)');

            const realtimeLabels = @Html.Raw(Json.Serialize(Model.ApiResponseLabels));
            const realtimeData = @Html.Raw(Json.Serialize(Model.ApiResponseValues));
            
            const historyLabels = @Html.Raw(Json.Serialize(Model.ChartLabels));
            const historyData = @Html.Raw(Json.Serialize(Model.ChartValues));

            const chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: realtimeLabels,
                    datasets: [{
                        label: 'Interactions',
                        data: realtimeData,
                        borderColor: '#059669',
                        borderWidth: 4,
                        backgroundColor: gradient,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 6,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#059669',
                        pointBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { 
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#0f172a',
                            titleFont: { size: 13, weight: 'bold' },
                            bodyFont: { size: 12 },
                            padding: 12,
                            displayColors: false,
                            borderColor: 'rgba(255,255,255,0.1)',
                            borderWidth: 1
                        }
                    },
                    scales: {
                        x: { 
                            display: true, 
                            grid: { display: false }, 
                            ticks: { font: { weight: 'bold', size: 10 }, color: '#64748b' } 
                        },
                        y: { 
                            display: true,
                            beginAtZero: true,
                            suggestedMax: 10,
                            grid: { color: 'rgba(148, 163, 184, 0.05)', drawBorder: false },
                            ticks: { font: { weight: 'bold', size: 10 }, color: '#475569', stepSize: 2 }
                        }
                    }
                }
            });

            const btnRealtime = document.getElementById('btn-realtime');
            const btnHistory = document.getElementById('btn-history');

            btnRealtime.addEventListener('click', () => {
                btnRealtime.classList.add('bg-slate-800', 'text-white', 'shadow-sm');
                btnRealtime.classList.remove('text-slate-500');
                
                btnHistory.classList.remove('bg-slate-800', 'text-white', 'shadow-sm');
                btnHistory.classList.add('text-slate-500');

                chart.data.labels = realtimeLabels;
                chart.data.datasets[0].data = realtimeData;
                chart.update();
            });

            btnHistory.addEventListener('click', () => {
                btnHistory.classList.add('bg-slate-800', 'text-white', 'shadow-sm');
                btnHistory.classList.remove('text-slate-500');
                
                btnRealtime.classList.remove('bg-slate-800', 'text-white', 'shadow-sm');
                btnRealtime.classList.add('text-slate-500');

                chart.data.labels = historyLabels;
                chart.data.datasets[0].data = historyData;
                chart.update();
            });
            // Phase 2: Heatmap Chart
            const heatmapCtx = document.getElementById('heatmapChart').getContext('2d');
            new Chart(heatmapCtx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.HeatmapLabels)),
                    datasets: [
                        {
                            label: 'Students',
                            data: @Html.Raw(Json.Serialize(ViewBag.StudentConcentration)),
                            backgroundColor: 'rgba(59, 130, 246, 0.8)',
                            borderRadius: 8,
                            barThickness: 12
                        },
                        {
                            label: 'Supervisors',
                            data: @Html.Raw(Json.Serialize(ViewBag.SupervisorCapacity)),
                            backgroundColor: 'rgba(16, 185, 129, 0.8)',
                            borderRadius: 8,
                            barThickness: 12
                        }
                    ]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { 
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#0f172a',
                            padding: 12,
                            titleFont: { size: 13 },
                            bodyFont: { size: 12 }
                        }
                    },
                    scales: {
                        x: { 
                            grid: { color: 'rgba(0,0,0,0.03)' },
                            ticks: { font: { weight: 'bold', size: 10 }, color: '#64748b' }
                        },
                        y: { 
                            grid: { display: false },
                            ticks: { font: { weight: 'bold', size: 10 }, color: '#475569' }
                        }
                    }
                }
            });
        });
    </script>
}
