@{
    ViewData["Title"] = "Broadcast Center";
    Layout = "_AdminLayout";
    var successMessage = TempData["SuccessMessage"] as string;
}

<div class="space-y-8 mt-6 pb-20 animate-fade-in-up">
    <!-- Header Architecture -->
    <header class="glass-panel p-10 lg:p-12 rounded-[3.5rem] relative overflow-hidden group mb-10">
        <div class="absolute -right-20 -top-20 w-96 h-96 bg-blue-400/20 rounded-full blur-[120px] group-hover:bg-blue-400/30 transition-all duration-700"></div>
        <div class="absolute -left-20 -bottom-20 w-80 h-80 bg-emerald-400/10 rounded-full blur-[100px] group-hover:bg-emerald-400/20 transition-all duration-700"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <p class="text-[11px] uppercase tracking-[0.2em] font-black text-blue-600 mb-2">Mass Communication</p>
                <h1 class="text-4xl md:text-5xl font-black text-slate-900 font-headline leading-tight tracking-tight mb-2">Broadcast <span class="text-blue-600">Hub</span></h1>
                <p class="text-[14px] font-semibold text-slate-500 mt-4 max-w-xl">
                    Dispatch prioritized notifications across the entire academic population.
                </p>
            </div>
            <div class="hidden md:flex gap-3">
                <span class="px-4 py-2 rounded-2xl bg-blue-500/10 border border-blue-500/20 text-[10px] font-black uppercase tracking-widest text-blue-600 shadow-sm flex items-center gap-2">
                    <span class="material-symbols-outlined text-[16px]">campaign</span> BROADCAST MODE
                </span>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="p-6 rounded-[2rem] bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 font-bold text-sm animate-toast-slide flex items-center gap-4">
            <span class="material-symbols-outlined">send</span>
            @successMessage
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Message Composer -->
        <div class="lg:col-span-8">
            <div class="glass-panel p-10 lg:p-12 rounded-[3.5rem] bg-white shadow-2xl border border-slate-100">
                <div class="flex items-center gap-4 mb-10">
                    <div class="w-12 h-12 bg-blue-600 text-white rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/20">
                        <span class="material-symbols-outlined">edit_note</span>
                    </div>
                     <h3 class="text-xl font-black text-slate-900 font-headline">New Transmission</h3>
                </div>

                <form asp-action="SendBroadcast" method="post" class="space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-3">
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] ml-1">Target Population</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">groups</span>
                                <select name="targetRole" class="w-full pl-12 pr-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-[14px] font-bold text-slate-900 focus:ring-2 focus:ring-blue-500/20 outline-none transition-all cursor-pointer">
                                    <option value="All">All Users</option>
                                    <option value="Student">All Students</option>
                                    <option value="Supervisor">All Supervisors</option>
                                </select>
                            </div>
                        </div>

                        <div class="space-y-3">
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] ml-1">Broadcast Title</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">label_important</span>
                                <input type="text" name="title" placeholder="e.g. Important Deadline Update" class="w-full pl-12 pr-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-[14px] font-bold text-slate-900 focus:ring-2 focus:ring-blue-500/20 outline-none transition-all" required />
                            </div>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] ml-1">Message Payload</label>
                        <textarea name="message" rows="5" placeholder="Enter the detailed announcement here..." class="w-full p-6 bg-slate-50 border border-slate-200 rounded-[2rem] text-[14px] font-bold text-slate-900 focus:ring-2 focus:ring-blue-500/20 outline-none transition-all resize-none" required></textarea>
                    </div>

                    <div class="pt-10 border-t border-slate-100 flex flex-col md:flex-row items-center justify-between gap-6">
                        <p class="text-[11px] font-semibold text-slate-400 max-w-sm">
                            <span class="text-blue-500 font-bold">Note:</span> Broadcasts are permanent and will trigger push notifications across the network.
                        </p>
                        <button type="submit" class="w-full md:w-auto px-12 py-4 bg-blue-600 text-white font-black uppercase tracking-widest text-[11px] rounded-2xl shadow-xl shadow-blue-600/20 hover:bg-blue-700 hover:-translate-y-1 transition-all flex items-center justify-center gap-3">
                            <span class="material-symbols-outlined text-[18px]">send</span>
                            Dispatch Broadcast
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- System Tips -->
        <div class="lg:col-span-4 space-y-6">
            <div class="glass-card p-8 rounded-[2.5rem] bg-slate-900 text-white border border-slate-700/50 shadow-2xl relative overflow-hidden group">
                <div class="absolute -right-10 -bottom-10 w-32 h-32 bg-blue-500/10 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700"></div>
                <h4 class="text-[10px] font-black text-blue-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[16px]">verified</span>
                    Transmission Protocol
                </h4>
                <div class="space-y-4 relative z-10">
                    <div class="flex gap-4 p-4 rounded-2xl bg-white/5 border border-white/10">
                        <span class="text-blue-400 font-black text-sm">01</span>
                        <p class="text-[11px] text-slate-400 font-medium">Broadcasts target both active and offline nodes.</p>
                    </div>
                    <div class="flex gap-4 p-4 rounded-2xl bg-white/5 border border-white/10">
                        <span class="text-blue-400 font-black text-sm">02</span>
                        <p class="text-[11px] text-slate-400 font-medium">Audit logs track the origin of every dispatch.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
