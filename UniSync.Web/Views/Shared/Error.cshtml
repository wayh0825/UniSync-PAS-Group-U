@model ErrorViewModel
@{
    ViewData["Title"] = "Signal Disturbance";
    Layout = "_Layout";
}

<div class="min-h-[70vh] flex items-center justify-center p-6 animate-fade-in-up">
    <div class="glass-panel p-12 md:p-16 rounded-[3rem] text-center max-w-2xl relative overflow-hidden">
        <div class="absolute -right-20 -top-20 w-64 h-64 bg-rose-100/30 rounded-full blur-3xl"></div>
        
        <div class="relative z-10">
            <div class="w-20 h-20 bg-rose-50 text-rose-500 rounded-3xl flex items-center justify-center mx-auto mb-8 shadow-sm">
                <span class="material-symbols-outlined text-4xl">error</span>
            </div>
            
            <h1 class="text-4xl font-black text-slate-900 font-headline mb-4">Signal <span class="text-rose-600">Interrupted.</span></h1>
            <p class="text-lg font-medium text-slate-500 mb-8 leading-relaxed">
                An anomaly occurred while processing your request. The synchronization protocol has been paused for safety.
            </p>

            @if (Model.ShowRequestId)
            {
                <div class="inline-flex items-center gap-2 bg-slate-50 px-4 py-2 rounded-xl border border-slate-100 mb-8">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">TRACE ID:</span>
                    <code class="text-xs font-bold text-slate-900">@Model.RequestId</code>
                </div>
            }

            <div class="pt-8 border-t border-slate-100">
                <a href="/" class="bg-slate-900 text-white font-black px-8 py-4 rounded-2xl hover:bg-slate-800 transition-all flex items-center justify-center gap-2 w-fit mx-auto">
                    <span class="material-symbols-outlined">restart_alt</span>
                    Reconnect to Hub
                </a>
            </div>
        </div>
    </div>
</div>
