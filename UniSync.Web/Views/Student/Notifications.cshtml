@model UniSync.Web.ViewModels.NotificationsPageViewModel
@{
    ViewData["Title"] = "Signal Center";
    Layout = "_Layout";
}

<style>
    .gradient-text-emerald {
        background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .notif-card {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .notif-card:hover {
        transform: translateX(8px);
    }
</style>

<div class="space-y-10 pb-20 animate-fade-in-up">
    <!-- Header Protocol -->
    <header class="glass-panel p-10 md:p-14 rounded-[3.5rem] relative overflow-hidden">
        <div class="absolute -right-20 -top-20 w-[40rem] h-[40rem] bg-emerald-500/5 rounded-full blur-[100px] pointer-events-none"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8 mb-12">
            <div>
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-900 border border-slate-700 shadow-sm mb-6">
                    <span class="material-symbols-outlined text-[12px] text-emerald-400">sensors</span>
                    <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest">Signal Intelligence</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-black text-slate-100 font-headline leading-none mb-4 tracking-tight">
                    Inbox <span class="gradient-text-emerald">Signals.</span>
                </h1>
                <p class="text-slate-400 font-medium text-lg max-w-xl">
                    Real-time administrative alerts, project updates, and collaboration invitations.
                </p>
            </div>

            <div class="flex gap-4">
                <div class="p-6 rounded-3xl bg-slate-900 border border-slate-700 min-w-[140px] text-center">
                    <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">Unread</p>
                    <p class="text-3xl font-black text-emerald-400">@Model.UnreadCount</p>
                </div>
                <div class="p-6 rounded-3xl bg-slate-900 border border-slate-700 min-w-[140px] text-center">
                    <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">Total</p>
                    <p class="text-3xl font-black text-slate-300">@Model.TotalCount</p>
                </div>
            </div>
        </div>

        <!-- Filter Nexus -->
        <div class="relative z-10 flex flex-wrap items-center gap-3">
            <a href="?filter=all" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Filter == "all" ? "bg-emerald-600 text-white shadow-lg" : "bg-slate-900 text-slate-500 border border-slate-700 hover:border-emerald-500/50")">All Signals</a>
            <a href="?filter=unread" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Filter == "unread" ? "bg-emerald-600 text-white shadow-lg" : "bg-slate-900 text-slate-500 border border-slate-700 hover:border-emerald-500/50")">Unread Only</a>
            <a href="?filter=read" class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(Model.Filter == "read" ? "bg-emerald-600 text-white shadow-lg" : "bg-slate-900 text-slate-500 border border-slate-700 hover:border-emerald-500/50")">Archived</a>
            
            <form method="get" class="ml-auto relative w-full md:w-64">
                <input type="hidden" name="filter" value="@Model.Filter" />
                <input type="text" name="search" value="@Model.Search" placeholder="SEARCH SIGNALS..." class="w-full bg-slate-900/50 border-slate-700 rounded-xl py-2.5 pl-10 pr-4 text-[10px] font-black text-slate-200 placeholder-slate-600 tracking-widest transition-all focus:ring-1 focus:ring-emerald-500" />
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 material-symbols-outlined text-[16px] text-slate-600">search</span>
            </form>
        </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Main Signal Stream -->
        <div class="lg:col-span-2 space-y-4">
            @if (Model.Notifications.Any())
            {
                foreach (var n in Model.Notifications)
                {
                    <div class="notif-card glass-card p-6 md:p-8 rounded-[2.5rem] border border-slate-800/50 @(!n.IsRead ? "bg-emerald-500/[0.02] border-emerald-500/20" : "")">
                        <div class="flex gap-6">
                            <div class="w-14 h-14 rounded-2xl bg-slate-900 border border-slate-700 flex flex-shrink-0 items-center justify-center text-slate-500 shadow-inner">
                                <span class="material-symbols-outlined text-2xl">@n.Icon</span>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between mb-2">
                                    <div class="flex items-center gap-3">
                                        <span class="text-[9px] font-black text-emerald-500 uppercase tracking-widest bg-emerald-500/10 px-2 py-0.5 rounded-md">@n.TypeLabel Service</span>
                                        @if(!n.IsRead) {
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                        }
                                    </div>
                                    <span class="text-[10px] font-bold text-slate-500">@n.TimeLabel</span>
                                </div>
                                <h3 class="text-xl font-black text-slate-100 font-headline mb-2">@n.Title</h3>
                                <p class="text-sm font-medium text-slate-400 mb-6 leading-relaxed">@n.Message</p>
                                
                                <div class="flex items-center gap-4">
                                    <a href="/Account/OpenNotification?id=@n.Id" class="px-6 py-2.5 rounded-xl bg-slate-900 border border-slate-700 text-white text-[10px] font-black uppercase tracking-widest hover:bg-emerald-600 hover:border-emerald-500 transition-all">
                                        @n.ActionLabel Signal
                                    </a>
                                    @if(!n.IsRead) {
                                        <button onclick="markAsRead(@n.Id, this)" class="text-[10px] font-black text-slate-500 uppercase tracking-widest hover:text-emerald-400 transition-colors">Mark as Read</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="glass-card p-24 rounded-[3.5rem] text-center">
                    <div class="w-20 h-20 bg-slate-900 border border-slate-700 text-slate-700 rounded-3xl flex items-center justify-center mx-auto mb-8">
                        <span class="material-symbols-outlined text-4xl">sensors_off</span>
                    </div>
                    <h3 class="text-2xl font-black text-slate-200 font-headline mb-2">No Active Signals</h3>
                    <p class="text-slate-500 font-medium text-sm">Signal spectrum is currently clear. No entries match your criteria.</p>
                </div>
            }
        </div>

        <!-- Sidebar Architecture -->
        <div class="space-y-10">
            <!-- Invitations Portal -->
            <section class="glass-panel p-8 rounded-[3rem] border-emerald-500/20 bg-emerald-500/5 relative overflow-hidden">
                <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
                
                <h3 class="text-xs font-black text-emerald-500 uppercase tracking-[0.3em] mb-8 relative z-10">Collaboration Hub</h3>
                
                @if (Model.PendingInvitations.Any())
                {
                    <div class="space-y-4 relative z-10">
                        @foreach (var invite in Model.PendingInvitations)
                        {
                            <div class="p-6 bg-slate-900/60 rounded-[2rem] border border-slate-700/50 shadow-inner">
                                <p class="text-[9px] font-black text-emerald-500 uppercase mb-3">Incoming Protocol Invite</p>
                                <h4 class="text-sm font-black text-slate-100 mb-4">@invite.ResearchSubmission?.Title</h4>
                                <div class="flex gap-2">
                                    <form asp-action="RespondToInvitation" method="post" class="flex-1">
                                        <input type="hidden" name="invitationId" value="@invite.Id" />
                                        <input type="hidden" name="accept" value="true" />
                                        <button type="submit" class="w-full bg-emerald-600 p-2.5 rounded-xl text-[9px] font-black text-white uppercase tracking-widest hover:bg-emerald-500 transition-all">Accept</button>
                                    </form>
                                    <form asp-action="RespondToInvitation" method="post" class="flex-1">
                                        <input type="hidden" name="invitationId" value="@invite.Id" />
                                        <input type="hidden" name="accept" value="false" />
                                        <button type="submit" class="w-full bg-slate-800 p-2.5 rounded-xl text-[9px] font-black text-slate-400 uppercase tracking-widest hover:bg-slate-700 transition-all">Reject</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="py-12 text-center relative z-10 opacity-40">
                        <span class="material-symbols-outlined text-3xl text-slate-500 mb-4">group_add</span>
                        <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest">No Active Invites</p>
                    </div>
                }
            </section>

            <!-- Quick Pulse -->
            <section class="glass-panel p-8 rounded-[3rem] border-slate-800/50 bg-slate-900/10">
                <h3 class="text-xs font-black text-slate-500 uppercase tracking-[0.3em] mb-8">Signal Matrix</h3>
                <div class="space-y-6">
                    <div class="flex items-center justify-between">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Daily Flux</span>
                        <span class="text-xs font-black text-slate-200">@Model.TodayCount Signals</span>
                    </div>
                    <div class="h-px bg-slate-800"></div>
                    <div class="flex items-center justify-between">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Unread State</span>
                        <span class="text-xs font-black text-emerald-500">@Model.UnreadCount Active</span>
                    </div>
                    <div class="h-px bg-slate-800"></div>
                    <div class="flex items-center justify-between">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Core Integrity</span>
                        <span class="text-[9px] font-black text-emerald-500 uppercase tracking-widest px-2 py-0.5 bg-emerald-500/10 rounded">Synchronized</span>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function markAsRead(id, btn) {
            try {
                // Placeholder for future AJAX if needed, but for now we'll just redirect to the mark-as-read handler
                window.location.href = `/Account/OpenNotification?id=${id}`;
            } catch (e) {}
        }
    </script>
}
