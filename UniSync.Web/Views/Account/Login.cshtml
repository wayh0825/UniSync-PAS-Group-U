@using UniSync.Web.ViewModels
@model LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connect - UniSync</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                        headline: ['"Outfit"', 'sans-serif'],
                    },
                    colors: {
                        emerald: {
                            500: '#10b981',
                            600: '#059669',
                            400: '#34d399',
                            950: '#064e3b',
                        },
                        slate: {
                            950: '#020617',
                            900: '#0f172a',
                            800: '#1e293b',
                            700: '#334155',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #020617;
            background-image: radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.05) 0px, transparent 50%),
                              radial-gradient(at 100% 100%, rgba(15, 23, 42, 0.05) 0px, transparent 50%);
        }

        .glass-panel {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        @@keyframes blob {
            0% { transform: translate(0px, 0px) scale(1); }
            33% { transform: translate(30px, -50px) scale(1.1); }
            66% { transform: translate(-20px, 20px) scale(0.9); }
            100% { transform: translate(0px, 0px) scale(1); }
        }

        .animate-blob {
            animation: blob 10s infinite alternate ease-in-out;
        }

        .input-dark {
            background: rgba(30, 41, 59, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            color: white;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .input-dark:focus {
            background: rgba(30, 41, 59, 0.6);
            border-color: #10b981;
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
            outline: none;
        }

        .btn-glow:hover {
            box-shadow: 0 0 30px rgba(16, 185, 129, 0.3);
        }
    </style>
</head>
<body class="font-sans antialiased min-h-screen flex items-center justify-center p-6 lg:p-12 relative overflow-hidden">

    <!-- Decorative Elements -->
    <div class="fixed top-0 -left-20 w-96 h-96 bg-emerald-600/10 rounded-full blur-[100px] animate-blob"></div>
    <div class="fixed bottom-0 -right-20 w-96 h-96 bg-slate-800/20 rounded-full blur-[100px] animate-blob" style="animation-delay: -5s;"></div>

    <div class="w-full max-w-[1100px] grid lg:grid-cols-2 rounded-[3.5rem] overflow-hidden glass-panel shadow-2xl relative z-10 border border-white/5">
        
        <!-- Branding Side -->
        <div class="hidden lg:flex flex-col justify-between p-16 bg-slate-950/80 relative overflow-hidden">
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-emerald-600/10 rounded-full blur-3xl"></div>
            
            <div class="relative z-10">
                <div class="flex items-center gap-3 mb-20">
                    <div class="w-10 h-10 rounded-xl bg-emerald-600 flex items-center justify-center text-white">
                        <span class="material-symbols-outlined font-bold">hub</span>
                    </div>
                    <span class="text-2xl font-black text-white font-headline tracking-tighter">UniSync</span>
                </div>

                <h1 class="text-5xl font-black text-white font-headline leading-[1.1] mb-8">
                    Project <br/>
                    <span class="text-emerald-500">Approvals.</span> <br/>
                    Simplified.
                </h1>
                <p class="text-slate-400 font-medium text-lg leading-relaxed max-w-sm">
                    Access the centralized dashboard for project submissions, faculty evaluations, and supervisor linking.
                </p>
            </div>

            <div class="relative z-10 flex items-center gap-6">
                <div class="p-5 rounded-2xl bg-white/5 border border-white/10 flex items-center gap-4 backdrop-blur-md">
                    <div class="w-10 h-10 rounded-full bg-emerald-600 flex items-center justify-center">
                        <span class="material-symbols-outlined text-white text-lg">verified</span>
                    </div>
                    <div>
                        <p class="text-[9px] font-black text-emerald-400 uppercase tracking-widest">Connection</p>
                        <p class="text-xs font-bold text-white">End-to-End Encrypted</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Form Side -->
        <div class="p-10 md:p-16 lg:p-20 flex flex-col justify-center">
            <div class="max-w-sm mx-auto w-full">
                <div class="mb-12 text-center lg:text-left">
                    <h2 class="text-3xl font-black text-white font-headline mb-3 tracking-tight">Login.</h2>
                    <p class="text-slate-400 font-medium text-sm">Welcome back to the Project Portal.</p>
                </div>

                <form asp-controller="Account" asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="p-4 rounded-xl bg-red-950/20 border border-red-500/20 text-red-400 text-xs font-bold flex gap-3 animate-pulse">
                            <span class="material-symbols-outlined text-sm">error</span>
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <div class="space-y-5">
                        <div class="group">
                            <label asp-for="Email" class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Email Address</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-500 group-focus-within:text-emerald-500 transition-colors">alternate_email</span>
                                <input asp-for="Email" type="email" placeholder="Enter your university email" required
                                       class="input-dark w-full rounded-2xl py-4 pl-12 pr-4 text-sm font-medium" />
                            </div>
                        </div>

                        <div class="group">
                            <label asp-for="Password" class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Password</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-500 group-focus-within:text-emerald-500 transition-colors">lock</span>
                                <input asp-for="Password" id="password-field" type="password" placeholder="Enter your password" required
                                       class="input-dark w-full rounded-2xl py-4 pl-12 pr-12 text-sm font-medium" />
                                <button type="button" id="toggle-password" class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center text-slate-500 hover:text-emerald-400 transition-colors z-20 focus:outline-none">
                                    <span class="material-symbols-outlined text-xl pointer-events-none" id="toggle-icon">visibility</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center justify-between">
                        <label class="inline-flex items-center gap-3 cursor-pointer select-none">
                            <input asp-for="RememberMe" type="checkbox" class="w-5 h-5 rounded-lg border-white/5 bg-slate-800 text-emerald-600 focus:ring-emerald-500/20" />
                            <span class="text-[13px] font-bold text-slate-400">Remember me</span>
                        </label>
                    </div>

                    <button type="submit" class="btn-premium btn-glow w-full bg-emerald-600 hover:bg-emerald-500 text-white font-black py-5 rounded-2xl shadow-xl shadow-emerald-950 transition-all font-headline text-lg tracking-tight">
                        Sign In
                    </button>
                    
                    <div class="text-center">
                        <a href="@Url.Action("ForgotPassword", "Account")" class="text-[11px] font-black text-emerald-500 hover:text-emerald-400 uppercase tracking-widest">Forgot your password?</a>
                    </div>
                    
                    <!-- End of Form -->
                </form>
            </div>
        </div>
    </div>

    <footer class="fixed bottom-12 w-full text-center opacity-30 px-6">
        <p class="text-[9px] font-bold text-slate-500 uppercase tracking-[0.4em]">© 2026 UniSync Project Portal • Group U</p>
    </footer>

    <script>
        (function() {
            const field = document.getElementById('password-field');
            const btn = document.getElementById('toggle-password');
            const icon = document.getElementById('toggle-icon');

            if (btn && field) {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    const isPass = field.type === 'password';
                    field.type = isPass ? 'text' : 'password';
                    icon.textContent = isPass ? 'visibility_off' : 'visibility';
                    field.focus();
                });
            }
        })();
    </script>
</body>
</html>
