@model UniSync.Web.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
    Layout = "_Layout";
    var successMessage = TempData["ProfileSaved"]?.ToString();
    var passwordSavedMessage = TempData["PasswordSaved"]?.ToString();
    var passwordErrorMessage = TempData["PasswordError"]?.ToString();
}

<style>
    .gradient-emerald {
        background: linear-gradient(135deg, #059669 0%, #10b981 100%);
    }
    .text-gradient-emerald {
        background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .glass-input {
        background: rgba(15, 23, 42, 0.6) !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        backdrop-filter: blur(10px);
    }
    .glass-input:focus {
        border-color: rgba(16, 185, 129, 0.5) !important;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.1) !important;
    }
</style>

<div class="space-y-10 pb-20 animate-fade-in-up">
    <!-- Feedback Alerts -->
    @if (!string.IsNullOrWhiteSpace(successMessage) || !string.IsNullOrWhiteSpace(passwordSavedMessage) || !string.IsNullOrWhiteSpace(passwordErrorMessage))
    {
        var isError = !string.IsNullOrWhiteSpace(passwordErrorMessage);
        <div class="glass-panel px-8 py-5 rounded-[2rem] border @(isError ? "border-red-500/20 bg-red-500/5 text-red-400" : "border-emerald-500/20 bg-emerald-500/5 text-emerald-400") font-bold flex items-center gap-3 shadow-xl">
            <span class="material-symbols-outlined">@(isError ? "error" : "check_circle")</span>
            <span class="text-sm tracking-wide">@(successMessage ?? passwordSavedMessage ?? passwordErrorMessage)</span>
        </div>
    }

    <!-- Profile Header -->
    <header class="glass-panel p-10 md:p-14 rounded-[3.5rem] relative overflow-hidden border border-slate-800/50">
        <div class="absolute -right-20 -top-20 w-[30rem] h-[30rem] bg-emerald-500/5 rounded-full blur-[100px] pointer-events-none"></div>
        <div class="absolute -left-20 -bottom-20 w-[20rem] h-[20rem] bg-blue-500/5 rounded-full blur-[100px] pointer-events-none"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-center gap-12">
            <div class="relative group">
                <div class="absolute inset-0 bg-emerald-500 blur-2xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                <div class="relative w-28 h-28 md:w-32 md:h-32 rounded-[2.5rem] gradient-emerald text-white flex items-center justify-center text-4xl md:text-5xl font-black font-headline shadow-2xl border-4 border-slate-900">
                    @Model.Initials
                </div>
                <div class="absolute -bottom-2 -right-2 bg-slate-900 border border-slate-700 px-3 py-1 rounded-full shadow-lg">
                    <span class="text-[9px] font-black text-emerald-400 uppercase tracking-widest">Online</span>
                </div>
            </div>

            <div class="flex-1">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-900 border border-slate-700 text-emerald-500 text-[10px] font-black uppercase tracking-widest mb-6 shadow-sm">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                    @Model.RoleLabel Profile
                </div>
                <h1 class="text-5xl md:text-6xl font-black text-slate-100 font-headline tracking-tight mb-4 leading-none">@Model.FullName</h1>
                <div class="flex items-center gap-4 text-slate-400 font-bold font-headline">
                    <span class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px] text-slate-500">alternate_email</span>
                        @Model.Email
                    </span>
                </div>
            </div>
            
            <div class="bg-slate-900/40 backdrop-blur-xl rounded-[2.5rem] p-8 border border-slate-700/50 min-w-[240px] shadow-inner group transition-all hover:border-emerald-500/30">
                <div class="flex items-center justify-between mb-4">
                    <p class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">User ID</p>
                    <span class="material-symbols-outlined text-slate-700 text-[16px]">qr_code_2</span>
                </div>
                <p class="text-xs font-black text-slate-300 tracking-wider font-headline group-hover:text-emerald-400 transition-colors">@Model.UserId</p>
            </div>
        </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Settings Form -->
        <section class="glass-card p-10 md:p-14 rounded-[3rem] space-y-10 border border-slate-800/50 bg-slate-900/10">
            <div>
                <h3 class="text-2xl font-black text-slate-100 font-headline mb-3 tracking-tight">Profile Settings</h3>
                <p class="text-sm font-bold text-slate-500">Update your account information and contact details.</p>
            </div>

            <form asp-action="Profile" method="post" class="space-y-8">
                @Html.AntiForgeryToken()
                <div class="space-y-6">
                    <div class="space-y-3">
                        <label asp-for="FullName" class="text-[11px] font-black text-slate-500 uppercase tracking-widest ml-1"></label>
                        <div class="relative group">
                            <input asp-for="FullName" class="w-full glass-input rounded-2xl py-4.5 px-6 text-sm font-bold text-slate-200" />
                            <span class="absolute right-6 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-700 group-focus-within:text-emerald-500 transition-colors">person</span>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label asp-for="Email" class="text-[11px] font-black text-slate-500 uppercase tracking-widest ml-1"></label>
                        <div class="relative">
                            <input asp-for="Email" readonly="@(Model.IsStudent ? "readonly" : null)" 
                                   class="w-full glass-input rounded-2xl py-4.5 px-6 text-sm font-bold text-slate-200 @(Model.IsStudent ? "bg-slate-900/80 border-slate-800/50 opacity-60" : "")" />
                            <span class="absolute right-6 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-700">@(Model.IsStudent ? "lock" : "mail")</span>
                        </div>
                        @if(Model.IsStudent) {
                            <p class="text-[9px] font-black text-amber-500/60 uppercase tracking-widest ml-1">Academic identity is immutable</p>
                        }
                    </div>

                    <div class="space-y-3">
                        <label asp-for="PhoneNumber" class="text-[11px] font-black text-slate-500 uppercase tracking-widest ml-1"></label>
                        <div class="relative group">
                            <input asp-for="PhoneNumber" class="w-full glass-input rounded-2xl py-4.5 px-6 text-sm font-bold text-slate-200" placeholder="+94 7X XXX XXXX" />
                            <span class="absolute right-6 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-700 group-focus-within:text-emerald-500 transition-colors">call</span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-black py-5 rounded-2xl shadow-2xl shadow-emerald-900/20 transition-all active:scale-[0.98] uppercase tracking-widest text-xs flex items-center justify-center gap-3">
                    <span class="material-symbols-outlined text-[20px]">sync</span>
                    Save Changes
                </button>
            </form>
        </section>

        <!-- Security & Metrics -->
        <div class="space-y-10">
            <!-- Password Panel -->
            <section class="glass-card p-10 md:p-14 rounded-[3rem] space-y-10 border border-slate-800/50 bg-slate-900/10">
                <div>
                    <h3 class="text-2xl font-black text-slate-100 font-headline mb-3 tracking-tight">Security</h3>
                    <p class="text-sm font-bold text-slate-500">Update your account password.</p>
                </div>
                
                <form asp-action="ChangePassword" method="post" class="space-y-5">
                    @Html.AntiForgeryToken()
                    <div class="relative group">
                        <input type="password" name="CurrentPassword" placeholder="CURRENT PASSWORD" required 
                               class="w-full glass-input rounded-2xl py-4.5 px-6 text-[10px] font-black text-slate-200 placeholder:text-slate-700 tracking-widest" />
                        <span class="absolute right-6 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-700 group-focus-within:text-emerald-500">key</span>
                    </div>
                    <div class="relative group">
                        <input type="password" name="NewPassword" placeholder="NEW PASSWORD" required 
                               class="w-full glass-input rounded-2xl py-4.5 px-6 text-[10px] font-black text-slate-200 placeholder:text-slate-700 tracking-widest" />
                        <span class="absolute right-6 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-700 group-focus-within:text-emerald-500">enhanced_encryption</span>
                    </div>
                    <div class="relative group">
                        <input type="password" name="ConfirmPassword" placeholder="VERIFY NEW PASSWORD" required 
                               class="w-full glass-input rounded-2xl py-4.5 px-6 text-[10px] font-black text-slate-200 placeholder:text-slate-700 tracking-widest" />
                        <span class="absolute right-6 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-700 group-focus-within:text-emerald-500">security</span>
                    </div>
                    
                    <button type="submit" class="w-full bg-slate-800 hover:bg-slate-700 text-slate-100 font-black py-5 rounded-2xl transition-all active:scale-[0.98] uppercase tracking-widest text-[11px] shadow-lg border border-slate-700/50 mt-4">
                        Save New Password
                    </button>
                </form>
            </section>

            <!-- Role Specific Card -->
            @if (Model.IsSupervisor)
            {
                <section class="glass-panel p-10 rounded-[3rem] border border-emerald-500/20 bg-emerald-500/5 relative overflow-hidden">
                    <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
                    
                    <div class="flex items-center justify-between mb-8 relative z-10">
                        <h3 class="text-xs font-black text-emerald-500 uppercase tracking-[0.3em]">Telemetry Hub</h3>
                        <span class="material-symbols-outlined text-emerald-800 text-[18px]">hub</span>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-6 relative z-10">
                        <div class="bg-slate-900/60 p-6 rounded-3xl border border-slate-700/50 shadow-inner group hover:border-emerald-500/30 transition-all">
                            <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-2">Supervised Projects</p>
                            <p class="text-3xl font-black text-slate-100 font-headline group-hover:text-emerald-400">@Model.SupervisorLinkedCount</p>
                        </div>
                        <div class="bg-slate-900/60 p-6 rounded-3xl border border-slate-700/50 shadow-inner group hover:border-emerald-500/30 transition-all">
                            <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-2">Approved Proposals</p>
                            <p class="text-3xl font-black text-slate-100 font-headline group-hover:text-emerald-400">@Model.SupervisorApprovedCount</p>
                        </div>
                    </div>
                </section>
            }
        </div>
    </div>
</div>
