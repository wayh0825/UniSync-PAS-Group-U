@using UniSync.Web.ViewModels
@model ForgotPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - UniSync</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                        headline: ['"Outfit"', 'sans-serif'],
                    },
                    colors: {
                        emerald: {
                            500: '#10b981',
                            600: '#059669',
                            400: '#34d399',
                        },
                        slate: {
                            950: '#020617',
                            900: '#0f172a',
                            800: '#1e293b',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #020617;
            background-image: radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.05) 0px, transparent 50%);
            min-height: 100vh;
        }

        .glass-panel {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .input-dark {
            background: rgba(30, 41, 59, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            color: white;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .input-dark:focus {
            background: rgba(30, 41, 59, 0.6);
            border-color: #10b981;
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
            outline: none;
        }
    </style>
</head>
<body class="font-sans antialiased min-h-screen flex items-center justify-center p-6 relative overflow-hidden">

    <!-- Decorative Glow -->
    <div class="fixed top-0 -left-20 w-96 h-96 bg-emerald-600/10 rounded-full blur-[100px]"></div>

    <div class="w-full max-w-[500px] glass-panel p-12 lg:p-16 rounded-[3.5rem] shadow-2xl relative z-10 border border-white/5 text-center">
        
        <!-- UniSync Branding -->
        <div class="flex items-center justify-center gap-3 mb-12">
            <div class="w-10 h-10 rounded-xl bg-emerald-600 flex items-center justify-center text-white shadow-lg shadow-emerald-950/40">
                <span class="material-symbols-outlined text-xl">hub</span>
            </div>
            <span class="text-2xl font-black text-white font-headline tracking-tighter">UniSync</span>
        </div>

        <h1 class="text-3xl font-black text-white font-headline tracking-tighter mb-4">Reset Password.</h1>
        <p class="text-slate-400 font-medium mb-10 text-sm">Enter your university email address and we'll send you a link to reset your password.</p>

        <form asp-controller="Account" asp-action="ForgotPassword" method="post" class="space-y-8">
            @Html.AntiForgeryToken()

            @if (ViewData["Message"] != null)
            {
                <div class="p-4 rounded-xl bg-emerald-950/30 border border-emerald-500/20 text-emerald-400 text-xs font-bold">
                    @ViewData["Message"]
                </div>
            }

            <div class="space-y-2 text-left">
                <label asp-for="Email" class="block text-[11px] font-black text-slate-500 uppercase tracking-widest ml-1">Email Address</label>
                <div class="relative group">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-500 group-focus-within:text-emerald-500 transition-colors">alternate_email</span>
                    <input asp-for="Email" type="email" placeholder="Enter your university email" required
                           class="input-dark w-full rounded-2xl py-4 pl-12 pr-4 text-sm font-medium" />
                </div>
            </div>

            <div class="flex flex-col gap-4">
                <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-black py-5 rounded-2xl shadow-xl shadow-emerald-950 transition-all font-headline text-lg tracking-tight">
                    Send Reset Link
                </button>
                <a href="@Url.Action("Login", "Account")" class="inline-flex items-center justify-center gap-2 text-[11px] font-black text-slate-500 hover:text-white uppercase tracking-[0.2em] transition-colors mt-4">
                    <span class="material-symbols-outlined text-lg">arrow_back</span>
                    Back to Login
                </a>
            </div>
        </form>
    </div>

    <footer class="fixed bottom-12 w-full text-center opacity-30 px-6">
        <p class="text-[9px] font-bold text-slate-500 uppercase tracking-[0.4em]">© 2026 UniSync Project Portal • Group U</p>
    </footer>

</body>
</html>
