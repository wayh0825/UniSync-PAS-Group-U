@model List<(UniSync.Core.Entities.ApplicationUser User, string Role)>

@{
    ViewData["Title"] = "Manage Users";
    Layout = "_AdminLayout";
    bool isAdmin = ViewBag.IsAdmin == true;
}


<!-- Page Header -->
<header class="glass-panel p-10 lg:p-12 rounded-[3.5rem] relative overflow-hidden mb-10 group">
    <div class="absolute -right-20 -top-20 w-96 h-96 bg-emerald-400/20 rounded-full blur-[120px] group-hover:bg-emerald-400/30 transition-all duration-700"></div>
    <div class="absolute -left-20 -bottom-20 w-80 h-80 bg-blue-400/10 rounded-full blur-[100px] group-hover:bg-blue-400/20 transition-all duration-700"></div>
    
    <div class="relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
            <p class="text-[11px] font-black uppercase tracking-[0.2em] text-emerald-600 mb-2">User Administration</p>
            <h1 class="text-4xl md:text-5xl font-black text-slate-900 font-headline leading-tight tracking-tight">
                Manage <span class="text-emerald-600">Users</span>
            </h1>
            <p class="text-lg font-medium text-slate-500 mt-4 max-w-xl">
                Manage students, supervisors and administrators in the system.
            </p>
        </div>
        <div class="flex items-center gap-4">
            <a href="@Url.Action("ExportUsers", "Admin")" class="px-6 py-4 rounded-2xl bg-white text-slate-900 border border-slate-200 text-xs font-black uppercase tracking-widest hover:bg-slate-50 transition-all shadow-sm flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">download</span>
                Export CSV
            </a>
            <button onclick="openModal()" class="px-8 py-4 rounded-2xl bg-slate-900 text-white text-xs font-black uppercase tracking-widest hover:bg-slate-800 transition-all shadow-lg shadow-slate-900/10 flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">add</span>
                Add User
            </button>
        </div>
    </div>
</header>

<!-- Stats Architecture -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
    <div class="glass-card p-8 rounded-[2rem] flex items-center gap-6 hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-900/10 transition-all duration-300 group">
        <div class="w-14 h-14 rounded-2xl bg-emerald-500 text-white flex items-center justify-center shadow-lg shadow-emerald-500/20 group-hover:scale-110 transition-transform">
            <span class="material-symbols-outlined text-[28px]">how_to_reg</span>
        </div>
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1">Active Students</p>
            <p class="text-3xl font-black text-slate-900 font-headline">@ViewBag.ActiveStudents</p>
        </div>
    </div>

    <div class="glass-card p-8 rounded-[2rem] flex items-center gap-6 hover:-translate-y-2 hover:shadow-2xl hover:shadow-slate-900/10 transition-all duration-300 group">
        <div class="w-14 h-14 rounded-2xl bg-slate-900 text-white flex items-center justify-center shadow-lg shadow-slate-900/10 group-hover:scale-110 transition-transform">
            <span class="material-symbols-outlined text-[28px]">school</span>
        </div>
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1">Faculty Supervisors</p>
            <p class="text-3xl font-black text-slate-900 font-headline">@ViewBag.Supervisors</p>
        </div>
    </div>

    <div class="glass-card p-8 rounded-[2rem] flex items-center gap-6 hover:-translate-y-2 hover:shadow-2xl hover:shadow-blue-900/10 transition-all duration-300 group">
        <div class="w-14 h-14 rounded-2xl bg-slate-100 text-slate-500 flex items-center justify-center group-hover:bg-blue-100 group-hover:text-blue-600 transition-colors">
            <span class="material-symbols-outlined text-[28px] group-hover:scale-110 transition-transform">groups</span>
        </div>
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1">Total Users</p>
            <p class="text-3xl font-black text-slate-900 font-headline">@ViewBag.TotalItems</p>
        </div>
    </div>
</div>

<!-- Registry Tools -->
<div class="glass-panel p-8 rounded-[2.5rem] mb-10">
    <form method="get" class="flex flex-wrap items-center gap-4">
        <div class="relative flex-1 min-w-[300px] group">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-emerald-500 transition-colors">search</span>
            <input type="text" name="search" value="@ViewBag.SearchTerm" placeholder="Search by name, email or UID..." 
                   class="w-full bg-slate-50 border-none rounded-xl py-4 pl-12 pr-4 text-sm font-bold text-slate-900 placeholder:text-slate-400 focus:ring-2 focus:ring-emerald-500/10 transition-all" />
        </div>

        <select name="roleFilter" onchange="this.form.submit()"
               class="min-w-[170px] bg-slate-50 border-none rounded-xl px-6 py-4 text-sm font-bold text-slate-900 focus:ring-2 focus:ring-emerald-500/10 cursor-pointer appearance-none">
            <option value="">All Roles</option>
            <option value="Student" selected="@(ViewBag.RoleFilter == "Student")">Student</option>
            <option value="Supervisor" selected="@(ViewBag.RoleFilter == "Supervisor")">Faculty / Supervisor</option>
            @if (ViewBag.IsAdmin)
            {
                <option value="ModuleLeader" selected="@(ViewBag.RoleFilter == "ModuleLeader")">Module Leader</option>
            }
        </select>

        <button type="submit" class="px-8 py-4 rounded-xl bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest hover:bg-slate-800 transition-all">
            Filter
        </button>
    </form>
</div>

<!-- Main Registry Table -->
<div class="glass-panel rounded-[3rem] overflow-hidden mb-10">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-slate-50">
                    <th class="py-8 pl-10 pr-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Full Name</th>
                    <th class="py-8 px-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Email Address</th>
                    <th class="py-8 px-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Primary Role</th>
                    <th class="py-8 px-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Status</th>
                    <th class="py-8 pr-10 pl-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @foreach (var entry in Model)
                {
                    var user = entry.User;
                    var role = entry.Role;
                    string initials = (!string.IsNullOrEmpty(user.FullName) && user.FullName.Length >= 2) ? user.FullName.Substring(0, 2).ToUpper() : "U";
                    
                    <tr class="hover:bg-slate-50/50 transition-colors group">
                        <td class="py-6 pl-10 pr-4">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-slate-900 text-white flex items-center justify-center font-black text-xs">
                                    @initials
                                </div>
                                <div>
                                    <p class="font-black text-slate-900 text-sm">@user.FullName</p>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Registered User</p>
                                </div>
                            </div>
                        </td>
                        <td class="py-6 px-4 text-sm font-bold text-slate-500">@user.Email</td>
                        <td class="py-6 px-4">
                            <span class="px-3 py-1 rounded-lg bg-emerald-900/5 text-emerald-600 text-[10px] font-black uppercase tracking-widest">@role</span>
                        </td>
                        <td class="py-6 px-4">
                            @if(user.EmailConfirmed)
                            {
                                <div class="flex items-center gap-2">
                                    <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(52,211,153,0.5)]"></div>
                                    <span class="text-[11px] font-black text-slate-900 uppercase tracking-widest">Active</span>
                                </div>
                            }
                            else
                            {
                                <div class="flex items-center gap-2 opacity-40">
                                    <div class="w-1.5 h-1.5 rounded-full bg-slate-400"></div>
                                    <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Offline</span>
                                </div>
                            }
                        </td>
                        <td class="py-6 pr-10 pl-4">
                            <div class="flex justify-end gap-2">
                                <button onclick="openEditModal('@user.Id', '@user.FullName', '@user.Email', '@role', '@(user.EmailConfirmed ? "Active" : "Inactive")')" 
                                        class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-900 hover:text-white transition-all">
                                    <span class="material-symbols-outlined text-lg">edit</span>
                                </button>
                                <button onclick="openDeleteModal('@user.Id', '@user.FullName')" 
                                        class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-400 hover:bg-red-600 hover:text-white transition-all">
                                    <span class="material-symbols-outlined text-lg">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <div class="px-10 py-6 border-t border-slate-50 flex items-center justify-between">
        @{
            int currentPage = ViewBag.CurrentPage;
            int totalPages = ViewBag.TotalPages;
            int totalItems = ViewBag.TotalItems;
            int pageSize = ViewBag.PageSize;
            int startEntry = ((currentPage - 1) * pageSize) + 1;
            int endEntry = System.Math.Min(currentPage * pageSize, totalItems);
            if (totalItems == 0) startEntry = 0;
        }
        <p class="text-[11px] font-black text-slate-400 uppercase tracking-widest">
            Showing <span class="text-slate-900">@startEntry-@endEntry</span> of <span class="text-slate-900">@totalItems</span> Users
        </p>
        
        <div class="flex items-center gap-2">
            @if (currentPage > 1)
            {
                <a href="/Admin/ManageUsers?page=@(currentPage - 1)&search=@ViewBag.SearchTerm&roleFilter=@ViewBag.RoleFilter" class="w-10 h-10 rounded-xl flex items-center justify-center text-slate-400 hover:bg-slate-50 transition-colors">
                    <span class="material-symbols-outlined">chevron_left</span>
                </a>
            }

            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == currentPage)
                {
                    <span class="w-10 h-10 rounded-xl bg-slate-900 text-white flex items-center justify-center font-black text-xs shadow-lg shadow-slate-900/10">@i</span>
                }
                else
                {
                    <a href="/Admin/ManageUsers?page=@i&search=@ViewBag.SearchTerm&roleFilter=@ViewBag.RoleFilter" class="w-10 h-10 rounded-xl text-slate-900 text-xs font-black flex items-center justify-center hover:bg-slate-50 transition-colors">@i</a>
                }
            }

            @if (currentPage < totalPages)
            {
                <a href="/Admin/ManageUsers?page=@(currentPage + 1)&search=@ViewBag.SearchTerm&roleFilter=@ViewBag.RoleFilter" class="w-10 h-10 rounded-xl flex items-center justify-center text-slate-900 hover:bg-slate-100 transition-colors">
                    <span class="material-symbols-outlined">chevron_right</span>
                </a>
            }
        </div>
    </div>
</div>



@section Modals {
<!-- Premium Glassmorphism Create User Modal -->
<div id="createUserModal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="absolute inset-0 bg-slate-950/60 backdrop-blur-md cursor-pointer" onclick="closeModal()"></div>
    <div class="relative z-10 w-full max-w-[480px] bg-slate-900/80 backdrop-blur-2xl rounded-[2.5rem] p-10 border border-slate-700/50 shadow-[0_20px_60px_rgba(0,0,0,0.5)] transform scale-95 transition-transform duration-300" id="modalCard">
        <div class="flex justify-between items-start mb-6">
            <div>
                <h2 class="text-[24px] font-black tracking-tight text-white mb-1">Provision Account</h2>
                <p class="text-[13px] font-medium text-slate-400">Register a new user into the UniSync ecosystem.</p>
            </div>
            <button onclick="closeModal()" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-700 transition-colors">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
        <form method="post" asp-controller="Admin" asp-action="CreateUser" class="space-y-5">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-[10px] font-bold text-slate-400 tracking-[0.2em] uppercase mb-2 ml-1">Full Name</label>
                <input type="text" name="FullName" placeholder="Dr. John Doe" class="w-full bg-slate-950 border border-slate-700/50 rounded-xl px-4 py-3.5 text-[14px] text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all font-medium shadow-sm !important" required />
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-400 tracking-[0.2em] uppercase mb-2 ml-1">Email Address</label>
                <input type="email" name="Email" placeholder="john.doe@university.edu" class="w-full bg-slate-950 border border-slate-700/50 rounded-xl px-4 py-3.5 text-[14px] text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all font-medium shadow-sm !important" required />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 tracking-[0.2em] uppercase mb-2 ml-1">Role</label>
                    <div class="relative">
                        <select name="Role" class="w-full bg-slate-950 border border-slate-700/50 rounded-xl px-4 py-3.5 text-[14px] text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all font-medium shadow-sm appearance-none cursor-pointer !important">
                            <option value="Student">Student</option>
                            <option value="Supervisor">Faculty / Supervisor</option>
                            @if (isAdmin)
                            {
                                <option value="ModuleLeader">Module Leader</option>
                            }
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none text-[20px]">expand_more</span>
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 tracking-[0.2em] uppercase mb-2 ml-1">Account Status</label>
                    <div class="relative">
                        <select name="Status" class="w-full bg-slate-950 border border-slate-700/50 rounded-xl px-4 py-3.5 text-[14px] text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all font-medium shadow-sm appearance-none cursor-pointer !important">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none text-[20px]">expand_more</span>
                    </div>
                </div>
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-400 tracking-[0.2em] uppercase mb-2 ml-1">Temp Password</label>
                <input type="password" name="Password" placeholder="••••••••" class="w-full bg-slate-950 border border-slate-700/50 rounded-xl px-4 py-3.5 text-[14px] text-white placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all font-medium shadow-sm tracking-[0.2em] !important" required />
            </div>
            <div class="pt-6 flex items-center justify-end gap-3 mt-4">
                <button type="button" onclick="closeModal()" class="px-6 py-3 rounded-full text-[14px] font-bold text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-[14px] px-8 py-3 rounded-full shadow-lg shadow-emerald-600/20 transition-all transform hover:-translate-y-0.5 flex items-center gap-2">
                    Create Account
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Premium Edit User Modal -->
<div id="editUserModal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="absolute inset-0 bg-slate-950/60 backdrop-blur-md cursor-pointer" onclick="closeEditModal()"></div>
    <div class="relative z-10 w-full max-w-[480px] bg-slate-900/80 backdrop-blur-2xl rounded-[2.5rem] p-10 border border-slate-700/50 shadow-[0_20px_60px_rgba(0,0,0,0.5)] transform scale-95 transition-transform duration-300" id="editModalCard">
        <div class="flex justify-between items-start mb-6">
            <div>
                <h2 class="text-[24px] font-black tracking-tight text-white mb-1">Edit Account</h2>
                <p class="text-[13px] font-medium text-slate-400">Modify user information and system access roles.</p>
            </div>
            <button onclick="closeEditModal()" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-700 transition-colors">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
        <form method="post" asp-controller="Admin" asp-action="UpdateUser" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="editUserId" />
            <div>
                <label class="block text-[10px] font-bold text-slate-400 tracking-[0.2em] uppercase mb-2 ml-1">Full Name</label>
                <input type="text" name="FullName" id="editFullName" class="w-full bg-slate-950 border border-slate-700/50 rounded-xl px-4 py-3.5 text-[14px] text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all font-medium shadow-sm !important" required />
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-400 tracking-[0.2em] uppercase mb-2 ml-1">Email Address</label>
                <input type="email" name="Email" id="editEmail" class="w-full bg-slate-950 border border-slate-700/50 rounded-xl px-4 py-3.5 text-[14px] text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all font-medium shadow-sm !important" required />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 tracking-[0.2em] uppercase mb-2 ml-1">Role</label>
                    <div class="relative">
                        <select name="Role" id="editRole" class="w-full bg-slate-950 border border-slate-700/50 rounded-xl px-4 py-3.5 text-[14px] text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all font-medium shadow-sm appearance-none cursor-pointer !important">
                            <option value="Student">Student</option>
                            <option value="Supervisor">Faculty / Supervisor</option>
                            @if (isAdmin)
                            {
                                <option value="ModuleLeader">Module Leader</option>
                            }
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none text-[20px]">expand_more</span>
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 tracking-[0.2em] uppercase mb-2 ml-1">Account Status</label>
                    <div class="relative">
                        <select name="Status" id="editStatus" class="w-full bg-slate-950 border border-slate-700/50 rounded-xl px-4 py-3.5 text-[14px] text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all font-medium shadow-sm appearance-none cursor-pointer !important">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none text-[20px]">expand_more</span>
                    </div>
                </div>
            </div>
            <div class="pt-6 flex items-center justify-end gap-3 mt-4">
                <button type="button" onclick="closeEditModal()" class="px-6 py-3 rounded-full text-[14px] font-bold text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
                    Cancel
                </button>
                <button type="submit" class="bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-[14px] px-8 py-3 rounded-full shadow-lg shadow-emerald-600/20 transition-all transform hover:-translate-y-0.5 flex items-center gap-2">
                    Update Account
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteConfirmModal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="absolute inset-0 bg-slate-950/60 backdrop-blur-md cursor-pointer" onclick="closeDeleteModal()"></div>
    <div class="relative z-10 w-full max-w-[400px] bg-slate-900/90 backdrop-blur-2xl rounded-[2.5rem] p-8 border border-slate-700/50 shadow-[0_20px_60px_rgba(0,0,0,0.5)] transform scale-95 transition-transform duration-300" id="deleteModalCard">
        <div class="w-20 h-20 rounded-full bg-red-900/20 text-red-500 flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-[40px]">warning</span>
        </div>
        <div class="text-center mb-8">
            <h2 class="text-[20px] font-black tracking-tight text-white mb-2">Confirm Delete</h2>
            <p class="text-[14px] text-slate-400 font-medium">Are you sure you want to delete <span id="deleteUserName" class="font-bold text-red-500"></span>? This action cannot be undone.</p>
        </div>
        <form method="post" asp-controller="Admin" asp-action="DeleteUser" id="deleteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteUserId" />
            <div class="flex flex-col gap-3">
                <button type="submit" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold text-[14px] py-4 rounded-2xl shadow-lg shadow-red-500/20 transition-all flex items-center justify-center gap-2">
                    Delete Permanently
                </button>
                <button type="button" onclick="closeDeleteModal()" class="w-full py-4 text-[14px] font-bold text-slate-400 hover:text-white transition-colors">
                    Cancel and Go Back
                </button>
            </div>
        </form>
    </div>
</div>
}

@section Scripts {
    <script>
        // Create Modal
        function openModal() {
            const modal = document.getElementById('createUserModal');
            const card = document.getElementById('modalCard');
            modal.classList.replace('opacity-0', 'opacity-100');
            modal.classList.remove('pointer-events-none');
            card.classList.replace('scale-95', 'scale-100');
        }
        function closeModal() {
            const modal = document.getElementById('createUserModal');
            const card = document.getElementById('modalCard');
            modal.classList.replace('opacity-100', 'opacity-0');
            modal.classList.add('pointer-events-none');
            card.classList.replace('scale-100', 'scale-95');
        }

        // Edit Modal
        function openEditModal(id, name, email, role, status) {
            document.getElementById('editUserId').value = id;
            document.getElementById('editFullName').value = name;
            document.getElementById('editEmail').value = email;
            document.getElementById('editRole').value = role;
            document.getElementById('editStatus').value = status;

            const modal = document.getElementById('editUserModal');
            const card = document.getElementById('editModalCard');
            modal.classList.replace('opacity-0', 'opacity-100');
            modal.classList.remove('pointer-events-none');
            card.classList.replace('scale-95', 'scale-100');
        }
        function closeEditModal() {
            const modal = document.getElementById('editUserModal');
            const card = document.getElementById('editModalCard');
            modal.classList.replace('opacity-100', 'opacity-0');
            modal.classList.add('pointer-events-none');
            card.classList.replace('scale-100', 'scale-95');
        }

        // Delete Modal
        function openDeleteModal(id, name) {
            document.getElementById('deleteUserId').value = id;
            document.getElementById('deleteUserName').innerText = name;

            const modal = document.getElementById('deleteConfirmModal');
            const card = document.getElementById('deleteModalCard');
            modal.classList.replace('opacity-0', 'opacity-100');
            modal.classList.remove('pointer-events-none');
            card.classList.replace('scale-95', 'scale-100');
        }
        function closeDeleteModal() {
            const modal = document.getElementById('deleteConfirmModal');
            const card = document.getElementById('deleteModalCard');
            modal.classList.replace('opacity-100', 'opacity-0');
            modal.classList.add('pointer-events-none');
            card.classList.replace('scale-100', 'scale-95');
        }
    </script>
}
