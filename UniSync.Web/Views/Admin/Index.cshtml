@model UniSync.Web.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="space-y-10 pb-20 animate-fade-in-up">
    <!-- Header Protocol -->
    <header class="glass-panel p-10 lg:p-12 rounded-[3.5rem] relative overflow-hidden group">
        <div class="absolute -right-20 -top-20 w-96 h-96 bg-emerald-400/20 rounded-full blur-[120px] group-hover:bg-emerald-400/30 transition-all duration-700"></div>
        <div class="absolute -left-20 -bottom-20 w-80 h-80 bg-blue-400/10 rounded-full blur-[100px] group-hover:bg-blue-400/20 transition-all duration-700"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-emerald-600 mb-2">Central Authority</p>
                <h1 class="text-4xl md:text-5xl font-black text-slate-900 font-headline leading-tight tracking-tight">
                    System <span class="text-emerald-600">Overview</span>
                </h1>
                <p class="text-lg font-medium text-slate-500 max-w-2xl mt-4">
                    Monitor operations, user flow, and overall network telemetry in real-time.
                </p>
            </div>
            <div class="hidden md:flex gap-3">
                <span class="px-4 py-2 rounded-2xl bg-white/50 border border-slate-200/50 text-[10px] font-black uppercase tracking-widest text-slate-500 shadow-sm">
                    @(User.IsInRole("Administrator") ? "System Admin" : "Module Leader")
                </span>
            </div>
        </div>
    </header>

    <!-- System Telemetry Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Load Metric -->
        <div class="glass-card p-8 rounded-[2rem] relative overflow-hidden hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-900/10 transition-all duration-300 group shadow-md backdrop-blur-xl border border-slate-700/50 bg-slate-900/40">
            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-emerald-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-all"></div>
            <span class="material-symbols-outlined absolute right-6 top-6 text-emerald-500 opacity-20 text-4xl group-hover:scale-110 transition-transform">memory</span>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Submission Load</p>
            <p class="text-4xl font-black text-white font-headline mb-1">@Model.SubmissionLoadPercent<span class="text-xl text-emerald-500">%</span></p>
            <p class="text-[11px] font-bold text-slate-500 mt-2">@Model.ActiveSubmissions Active Streams</p>
        </div>

        <!-- Sync Metric -->
        <div class="glass-card p-8 rounded-[2rem] relative overflow-hidden hover:-translate-y-2 hover:shadow-2xl hover:shadow-blue-900/10 transition-all duration-300 group shadow-md backdrop-blur-xl border border-slate-700/50 bg-slate-900/40">
            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/20 transition-all"></div>
            <span class="material-symbols-outlined absolute right-6 top-6 text-blue-500 opacity-20 text-4xl group-hover:scale-110 transition-transform">hub</span>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Link Rate</p>
            <p class="text-4xl font-black text-white font-headline mb-1">@Model.LinkRatePercent<span class="text-xl text-blue-500">%</span></p>
            <p class="text-[11px] font-bold text-slate-500 mt-2">@Model.SuccessfulLinks Synced Projects</p>
        </div>

        <!-- User Metric -->
        <div class="glass-card p-8 rounded-[2rem] relative overflow-hidden hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-900/10 transition-all duration-300 group shadow-md backdrop-blur-xl border border-slate-700/50 bg-slate-900/40">
            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/20 transition-all"></div>
            <span class="material-symbols-outlined absolute right-6 top-6 text-purple-500 opacity-20 text-4xl group-hover:scale-110 transition-transform">group</span>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Platform Entities</p>
            <p class="text-4xl font-black text-white font-headline mb-1">@Model.TotalPlatformUsers</p>
            <p class="text-[11px] font-bold text-slate-500 mt-2">@Model.TotalStudents Students Registered</p>
        </div>

        @if (User.IsInRole("Administrator"))
        {
            <!-- Database Metric -->
            <div class="p-8 rounded-[2rem] relative overflow-hidden text-white transition-all duration-300 group @(Model.DatabaseConnected ? "bg-slate-900 shadow-xl shadow-slate-900/20" : "bg-red-600 shadow-xl shadow-red-600/30") hover:-translate-y-2 border border-slate-700/50">
                <div class="absolute -right-10 -bottom-10 w-32 h-32 @(Model.DatabaseConnected ? "bg-emerald-500/20" : "bg-black/20") rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700"></div>
                <span class="material-symbols-outlined absolute right-6 top-6 text-white opacity-20 text-4xl group-hover:rotate-12 transition-transform">database</span>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Database Protocol</p>
                <div class="flex items-center gap-3">
                    <div class="w-2.5 h-2.5 rounded-full @(Model.DatabaseConnected ? "bg-emerald-400" : "bg-red-300") animate-ping"></div>
                    <p class="text-3xl font-black font-headline text-white">@(Model.DatabaseConnected ? "Online" : "Failed")</p>
                </div>
                <p class="text-[11px] font-bold relative z-10 text-slate-500 mt-3">@Model.LastHealthCheck</p>
            </div>
        }
        else
        {
            <!-- Replacement card for Module Leader -->
            <div class="glass-card p-8 rounded-[2rem] relative overflow-hidden hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-900/10 transition-all duration-300 group shadow-md backdrop-blur-xl border border-slate-700/50 bg-slate-900/40">
                <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-emerald-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-all"></div>
                <span class="material-symbols-outlined absolute right-6 top-6 text-emerald-500 opacity-20 text-4xl group-hover:scale-110 transition-transform">assignment_ind</span>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Review Queue</p>
                <p class="text-4xl font-black text-white font-headline mb-1">@Model.RecentSubmissions.Count</p>
                <p class="text-[11px] font-bold text-slate-500 mt-2">Latest Actionable Projects</p>
            </div>
        }
    </div>

    <!-- Analytics Architecture -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Activity Graph -->
        <div class="lg:col-span-2 glass-panel p-8 rounded-[2.5rem] flex flex-col h-[400px]">
            <div class="flex justify-between items-start mb-8">
                <div>
                    <h3 class="text-xl font-black text-white font-headline">Live Activity</h3>
                    <p class="text-xs font-medium text-slate-400">Time-series analysis of interactions.</p>
                </div>
                <div class="bg-slate-900 border border-slate-700/50 p-1 rounded-xl flex gap-1">
                    <button id="btn-realtime" class="px-4 py-1.5 text-[10px] font-black uppercase tracking-widest bg-slate-800 text-white shadow-sm rounded-lg transition-all">Realtime</button>
                    <button id="btn-history" class="px-4 py-1.5 text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-white transition-all rounded-lg">History</button>
                </div>
            </div>
            <div class="flex-1 relative">
                <canvas id="activityChart"></canvas>
            </div>
        </div>

        @if (User.IsInRole("Administrator"))
        {
            <!-- Status Panel -->
            <div class="glass-card p-8 rounded-[2.5rem] flex flex-col">
                <h3 class="text-xl font-black text-white font-headline mb-6">System Services</h3>
                <div class="space-y-6 flex-1">
                    @foreach (var service in new[] { 
                        new { Name = "Web Application", Status = Model.WebAppActive, Color = "emerald" },
                        new { Name = "Database Server", Status = Model.DatabaseConnected, Color = "emerald" },
                        new { Name = "Notification Service", Status = Model.NotificationServiceActive, Color = "emerald" },
                        new { Name = "Plagiarism API", Status = Model.PlagiarismApiActive, Color = "amber" }
                    })
                    {
                        <div class="flex items-center justify-between p-4 rounded-2xl bg-slate-900/40 border border-slate-700/50">
                            <span class="text-sm font-bold text-white">@service.Name</span>
                            <div class="flex items-center gap-2">
                                <span class="text-[9px] font-black uppercase tracking-widest text-@service.Color-500">@(service.Status ? "Active" : "Idle")</span>
                                <div class="w-1.5 h-1.5 rounded-full bg-@service.Color-500"></div>
                            </div>
                        </div>
                    }
                </div>
                <a href="@Url.Action("AuditLogs", "Admin")" class="mt-8 w-full py-4 rounded-2xl bg-slate-900 text-white font-black text-xs text-center uppercase tracking-widest hover:bg-slate-800 transition-all">
                    View Audit Logs
                </a>
            </div>
        }
        else
        {
            <!-- Recent Activity Panel for Module Leader -->
            <div class="glass-card p-8 rounded-[2.5rem] flex flex-col">
                <h3 class="text-xl font-black text-white font-headline mb-6">Recent Alerts</h3>
                <div class="space-y-4 flex-1">
                    @foreach (var sub in Model.RecentSubmissions)
                    {
                        <div class="p-4 rounded-2xl bg-white/5 border border-slate-700/50">
                            <p class="text-xs font-black text-white mb-1">New Submission</p>
                            <p class="text-[10px] text-slate-400 font-medium">@sub.Title</p>
                        </div>
                    }
                </div>
                <a href="@Url.Action("AllocationOversight", "Admin")" class="mt-8 w-full py-4 rounded-2xl bg-emerald-500 text-slate-950 font-black text-xs text-center uppercase tracking-widest hover:bg-emerald-400 transition-all">
                    Manage Allocations
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const ctx = document.getElementById('activityChart').getContext('2d');
            const gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(16, 185, 129, 0.2)');
            gradient.addColorStop(1, 'rgba(16, 185, 129, 0)');

            const realtimeLabels = @Html.Raw(Json.Serialize(Model.ApiResponseLabels));
            const realtimeData = @Html.Raw(Json.Serialize(Model.ApiResponseValues));
            
            const historyLabels = @Html.Raw(Json.Serialize(Model.ChartLabels));
            const historyData = @Html.Raw(Json.Serialize(Model.ChartValues));

            const chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: realtimeLabels,
                    datasets: [{
                        label: 'Interactions',
                        data: realtimeData,
                        borderColor: '#059669',
                        borderWidth: 4,
                        backgroundColor: gradient,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 6,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#059669',
                        pointBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { display: true, grid: { display: false }, ticks: { font: { weight: 'bold', size: 10 }, color: '#94a3b8' } },
                        y: { display: false }
                    }
                }
            });

            const btnRealtime = document.getElementById('btn-realtime');
            const btnHistory = document.getElementById('btn-history');

            btnRealtime.addEventListener('click', () => {
                btnRealtime.classList.add('bg-slate-800', 'text-white', 'shadow-sm');
                btnRealtime.classList.remove('text-slate-500');
                
                btnHistory.classList.remove('bg-slate-800', 'text-white', 'shadow-sm');
                btnHistory.classList.add('text-slate-500');

                chart.data.labels = realtimeLabels;
                chart.data.datasets[0].data = realtimeData;
                chart.update();
            });

            btnHistory.addEventListener('click', () => {
                btnHistory.classList.add('bg-slate-800', 'text-white', 'shadow-sm');
                btnHistory.classList.remove('text-slate-500');
                
                btnRealtime.classList.remove('bg-slate-800', 'text-white', 'shadow-sm');
                btnRealtime.classList.add('text-slate-500');

                chart.data.labels = historyLabels;
                chart.data.datasets[0].data = historyData;
                chart.update();
            });
        });
    </script>
}
