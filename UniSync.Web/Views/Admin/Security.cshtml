@model UniSync.Web.ViewModels.SecurityDashboardViewModel

@{
    ViewData["Title"] = "Security Configuration";
    Layout = "_AdminLayout";
}

<div class="space-y-10 pb-20 animate-fade-in-up">
    <!-- Page Header -->
    <header class="glass-panel p-10 lg:p-12 rounded-[3.5rem] relative overflow-hidden group">
        <div class="absolute -right-20 -top-20 w-96 h-96 bg-emerald-400/20 rounded-full blur-[120px] group-hover:bg-emerald-400/30 transition-all duration-700"></div>
        <div class="absolute -left-20 -bottom-20 w-80 h-80 bg-blue-400/10 rounded-full blur-[100px] group-hover:bg-blue-400/20 transition-all duration-700"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-emerald-600 mb-2">Access Control</p>
                <h1 class="text-4xl md:text-5xl font-black text-slate-900 font-headline leading-tight tracking-tight">
                    Security <span class="text-emerald-600">Settings</span>
                </h1>
                <p class="text-lg font-medium text-slate-500 mt-4 max-w-xl">
                    Manage system access, encryption protocols, and API integrations securely.
                </p>
            </div>
            <button type="submit" form="security-settings-form" class="px-8 py-4 rounded-2xl bg-slate-900 text-white text-xs font-black uppercase tracking-widest hover:bg-slate-800 transition-all shadow-lg flex items-center gap-2 hover:-translate-y-1">
                <span class="material-symbols-outlined text-lg">admin_panel_settings</span>
                Save Policies
            </button>
        </div>
    </header>



    <form id="security-settings-form" asp-action="SaveSecuritySettings" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" id="enforce2FaForAdmins" name="enforce2FaForAdmins" value="@Model.TwoFactorForced.ToString().ToLowerInvariant()" />
        <input type="hidden" id="passwordComplexityEnabled" name="passwordComplexityEnabled" value="@Model.PasswordComplexityEnabled.ToString().ToLowerInvariant()" />
        <input type="hidden" name="maintenanceModeEnabled" value="@Model.MaintenanceModeEnabled.ToString().ToLowerInvariant()" />

        <!-- Main Split Cards container -->
        <div class="flex flex-col lg:flex-row gap-0 glass-panel rounded-[3.5rem] shadow-xl overflow-hidden min-h-[460px] bg-slate-900/60 backdrop-blur-xl border border-slate-700/50">
            
            <!-- Global Security Policies -->
            <div class="flex-1 p-10 border-r border-slate-700/50 relative z-10 w-full lg:w-1/2">
                <div class="flex items-center gap-4 mb-10 mt-2">
                    <div class="w-12 h-12 rounded-2xl bg-blue-500/10 text-blue-400 flex items-center justify-center shrink-0 border border-blue-500/20">
                        <span class="material-symbols-outlined text-[22px]">policy</span>
                    </div>
                    <h2 class="text-[22px] font-headline font-black text-white leading-tight">Global Security<br/>Settings</h2>
                </div>

                <div class="space-y-8 pl-1">
                    <!-- Toggle 1 -->
                    <div class="flex justify-between items-start gap-4">
                        <div>
                            <h4 class="text-[15px] font-bold text-white mb-0.5">Enforce 2FA for Admins</h4>
                            <p class="text-[12px] text-slate-400 font-medium max-w-[280px]">Requires TOTP or Hardware key for all admin context logins.</p>
                        </div>
                        <button type="button" id="toggle-2fa" class="relative w-[48px] h-[26px] @(Model.TwoFactorForced ? "bg-emerald-500" : "bg-slate-700") rounded-full mt-1 transition-colors outline-none focus:ring-4 focus:ring-slate-800">
                            <span id="toggle-2fa-knob" class="absolute top-1 @(Model.TwoFactorForced ? "left-[24px]" : "left-[4px]") w-[18px] h-[18px] bg-white rounded-full shadow transition-all"></span>
                        </button>
                    </div>

                    <!-- Toggle 2 -->
                    <div class="flex justify-between items-start gap-4">
                        <div>
                            <h4 class="text-[15px] font-bold text-white mb-0.5">Password Complexity Checks</h4>
                            <p class="text-[12px] text-slate-400 font-medium max-w-[280px]">Symbols, numbers, and case requirements enabled globally.</p>
                        </div>
                        <button type="button" id="toggle-password" class="relative w-[48px] h-[26px] @(Model.PasswordComplexityEnabled ? "bg-emerald-500" : "bg-slate-700") rounded-full mt-1 transition-colors outline-none">
                            <span id="toggle-password-knob" class="absolute top-1 @(Model.PasswordComplexityEnabled ? "left-[24px]" : "left-[4px]") w-[18px] h-[18px] bg-white rounded-full shadow transition-all"></span>
                        </button>
                    </div>

                    <!-- Input Box -->
                    <div class="pt-2">
                        <h4 class="text-[13px] font-bold text-white mb-3">Session Timeout Trigger (Mins)</h4>
                        <div class="relative w-full max-w-[280px]">
                            <input type="number" min="5" max="180" name="sessionTimeoutMinutes" value="@Model.SessionTimeoutMinutes" class="w-full bg-slate-950 border border-slate-700 shadow-sm rounded-xl py-3 px-4 text-[15px] font-bold text-white focus:outline-none focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/20" />
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black tracking-widest text-slate-500">MINS</span>
                        </div>
                        <p class="text-[10px] text-slate-500 font-bold italic mt-3 max-w-[280px]">Automated inactivity threshold kill-switch.</p>
                    </div>
                </div>
            </div>

 
        </div>
    </form>

    <div class="grid grid-cols-1 gap-8">
        <div class="glass-card p-6 rounded-[2rem] shadow-sm pb-8 border border-slate-700/50 border-t-0 bg-gradient-to-b from-slate-800/10 to-slate-900/60">
            <div class="w-10 h-10 rounded-2xl bg-amber-500/10 text-amber-500 border border-amber-500/20 flex items-center justify-center mb-5 mt-1">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">lock</span>
            </div>
            <h3 class="text-[15px] font-headline font-black text-white mb-2.5">Encryption Protocol</h3>
            <p class="text-[12px] text-slate-400 font-medium leading-relaxed pr-4">
                @Model.DataEncyptionSummary
            </p>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        (function () {
            const toggle2Fa = document.getElementById('toggle-2fa');
            const toggle2FaKnob = document.getElementById('toggle-2fa-knob');
            const togglePassword = document.getElementById('toggle-password');
            const togglePasswordKnob = document.getElementById('toggle-password-knob');

            const input2Fa = document.getElementById('enforce2FaForAdmins');
            const inputPassword = document.getElementById('passwordComplexityEnabled');

            function setToggleState(toggle, knob, hiddenInput, enabled) {
                toggle.classList.toggle('bg-emerald-500', enabled);
                toggle.classList.toggle('bg-slate-700', !enabled);

                knob.classList.toggle('left-[24px]', enabled);
                knob.classList.toggle('left-[4px]', !enabled);

                hiddenInput.value = enabled ? 'true' : 'false';
            }

            // Only bind if elements exist
            if(toggle2Fa) {
                toggle2Fa.addEventListener('click', function () {
                    setToggleState(toggle2Fa, toggle2FaKnob, input2Fa, input2Fa.value !== 'true');
                });
            }

            if(togglePassword) {
                togglePassword.addEventListener('click', function () {
                    setToggleState(togglePassword, togglePasswordKnob, inputPassword, inputPassword.value !== 'true');
                });
            }
        })();


    </script>
}
