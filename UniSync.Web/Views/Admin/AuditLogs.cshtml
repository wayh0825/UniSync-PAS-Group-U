@model IEnumerable<UniSync.Web.ViewModels.AuditLogItemViewModel>

@{
    ViewData["Title"] = "Audit Logs";
    Layout = "_AdminLayout";
}

<div class="space-y-10 pb-20 animate-fade-in-up">
    <!-- Header Architecture -->
    <header class="glass-panel p-10 lg:p-12 rounded-[3.5rem] relative overflow-hidden group mb-10">
        <div class="absolute -right-20 -top-20 w-96 h-96 bg-emerald-400/20 rounded-full blur-[120px] group-hover:bg-emerald-400/30 transition-all duration-700"></div>
        <div class="absolute -left-20 -bottom-20 w-80 h-80 bg-blue-400/10 rounded-full blur-[100px] group-hover:bg-blue-400/20 transition-all duration-700"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <p class="text-[11px] font-black uppercase tracking-[0.2em] text-emerald-600 mb-2">System Events</p>
                <h1 class="text-4xl md:text-5xl font-black text-slate-900 font-headline leading-tight tracking-tight">
                    Audit <span class="text-emerald-600">Logs</span>
                </h1>
                <p class="text-lg font-medium text-slate-500 max-w-2xl mt-4">
                    Monitor system events, user actions, and security telemetry logs.
                </p>
            </div>
            <div class="hidden md:flex gap-3">
                <span class="px-4 py-2 rounded-2xl bg-slate-900/40 border border-slate-700/50 text-[10px] font-black uppercase tracking-widest text-slate-400 shadow-sm">Security Admin</span>
            </div>
        </div>
    </header>

    <!-- Audit Registry -->
    <section class="glass-panel rounded-[2.5rem] overflow-hidden">
        <div class="p-8 border-b border-slate-700/50 flex justify-between items-center">
            <h3 class="text-xl font-black text-white font-headline">Events List</h3>
            <div class="flex gap-4">
                <a href="@Url.Action("ExportAuditLogs", "Admin")" class="px-6 py-2.5 rounded-xl bg-slate-900 border border-slate-700 text-[10px] font-black uppercase tracking-widest text-white shadow-lg shadow-slate-900/10 hover:bg-slate-800 transition-all text-center">Export Log</a>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-slate-900/40 border-b border-slate-700/50">
                        <th class="py-5 px-8 text-[10px] font-black text-slate-400 uppercase tracking-widest">Event</th>
                        <th class="py-5 px-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Actor Identity</th>
                        <th class="py-5 px-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Source</th>
                        <th class="py-5 px-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Severity</th>
                        <th class="py-5 px-8 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Timestamp</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-700/50">
                    @foreach (var log in Model)
                    {
                        <tr class="hover:bg-slate-800/20 transition-all">
                            <td class="py-6 px-8">
                                <p class="text-sm font-black text-white">@log.EventType</p>
                                <p class="text-[10px] font-bold text-slate-400 truncate max-w-[200px] mt-1">@log.Details</p>
                            </td>
                            <td class="py-6 px-6">
                                <span class="px-3 py-1 rounded-lg bg-slate-900/50 border border-slate-700/50 text-[11px] font-bold text-white">@log.UserName</span>
                                <p class="text-[9px] font-black uppercase tracking-widest text-emerald-500 mt-1.5 ml-1">@log.UserRole</p>
                            </td>
                            <td class="py-6 px-6">
                                <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">IP: @(string.IsNullOrWhiteSpace(log.IpAddress) ? "Internal" : log.IpAddress)</span>
                            </td>
                            <td class="py-6 px-6">
                                @if (log.IsError)
                                {
                                    <span class="px-2.5 py-1 rounded-lg text-[9px] font-black uppercase tracking-widest bg-red-900/20 text-red-500 border border-red-500/20">Critical</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 rounded-lg text-[9px] font-black uppercase tracking-widest bg-emerald-900/20 text-emerald-400 border border-emerald-500/20">Info</span>
                                }
                            </td>
                            <td class="py-6 px-8 text-right">
                                <p class="text-[11px] font-black text-white">@log.TimestampUtc.ToLocalTime().ToString("MMM dd, yyyy")</p>
                                <p class="text-[9px] font-bold text-slate-500 uppercase mt-0.5">@log.TimestampUtc.ToLocalTime().ToString("HH:mm:ss") Loc</p>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="py-20 text-center">
                                <div class="flex flex-col items-center gap-4">
                                    <span class="material-symbols-outlined text-4xl text-slate-600">security_update_good</span>
                                    <p class="text-sm font-bold text-slate-400">No audit logs recorded for the selected filter.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
