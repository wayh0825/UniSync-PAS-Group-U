@{
    Layout = null;
    ViewData["Title"] = "Project Approval System";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>UniSync - Project Approval System</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                        headline: ['"Outfit"', 'sans-serif'],
                    },
                    colors: {
                        emerald: {
                            500: '#10b981',
                            600: '#059669',
                            400: '#34d399',
                        },
                        slate: {
                            950: '#020617',
                            900: '#0f172a',
                            800: '#1e293b',
                            700: '#334155',
                        }
                    }
                }
            }
        }
    </script>
    
    <style>
        body, html {
            background-color: #020617; 
            color: #f8fafc;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            width: 100%;
            height: 100%;
        }

        .glow-orb-1 {
            position: absolute;
            top: -10%;
            left: -10%;
            width: 60vw;
            height: 60vw;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.08) 0%, rgba(16, 185, 129, 0) 70%);
            border-radius: 50%;
            filter: blur(80px);
            z-index: 0;
            animation: float 20s infinite ease-in-out;
        }

        .glow-orb-2 {
            position: absolute;
            bottom: -20%;
            right: -10%;
            width: 70vw;
            height: 70vw;
            background: radial-gradient(circle, rgba(51, 65, 85, 0.1) 0%, rgba(51, 65, 85, 0) 70%);
            border-radius: 50%;
            filter: blur(100px);
            z-index: 0;
            animation: float 25s infinite ease-in-out reverse;
        }

        @@keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(60px, 40px) scale(1.1); }
            100% { transform: translate(0, 0) scale(1); }
        }

        .hero-title {
            background: linear-gradient(135deg, #ffffff 0%, #94a3b8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .hero-wrapper {
            position: relative;
            width: 100%;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #020617;
            overflow: hidden;
        }

        .hero-bg-image {
            position: absolute;
            inset: 0;
            background-image: url('@Url.Content("~/images/hero.png")');
            background-size: cover;
            background-position: center;
            opacity: 0.12;
            mask-image: linear-gradient(to bottom, black 0%, transparent 90%);
            -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 90%);
            pointer-events: none;
            z-index: 1;
        }

        .premium-card {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
        }

        .premium-card:hover {
            transform: translateY(-12px);
            background: rgba(15, 23, 42, 0.8);
            border-color: rgba(16, 185, 129, 0.2);
            box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.5);
        }

        .glass-nav {
            background: rgba(2, 6, 23, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            transition: all 0.4s ease;
        }

        .text-glow-emerald {
            text-shadow: 0 0 30px rgba(16, 185, 129, 0.5);
        }

        .btn-premium {
            position: relative;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-premium:active {
            transform: scale(0.97);
        }

        .grid-bg {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.03) 1px, transparent 0);
            background-size: 40px 40px;
            pointer-events: none;
        }
    </style>
</head>
<body class="font-sans antialiased text-slate-200 selection:bg-emerald-900 selection:text-emerald-100">

    <div class="hero-wrapper">
        <div class="hero-bg-image"></div>
        <div class="grid-bg"></div>
        <!-- Background Orbs -->
        <div class="glow-orb-1 pointer-events-none"></div>
        <div class="glow-orb-2 pointer-events-none"></div>

        <!-- Premium Navigation -->
        <nav class="w-full h-24 fixed top-0 z-50 flex items-center justify-between px-8 md:px-16 glass-nav">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-emerald-600 text-white flex items-center justify-center shadow-lg shadow-emerald-900/40">
                    <span class="material-symbols-outlined text-2xl font-bold">hub</span>
                </div>
                <span class="text-2xl font-black text-white font-headline tracking-tighter">UniSync</span>
            </div>

            <div class="flex items-center gap-4">
                <a href="@Url.Action("Login", "Account")" class="bg-white/5 border border-white/10 text-white text-[11px] font-black uppercase tracking-[0.2em] px-8 py-3 rounded-full transition-all hover:bg-emerald-600 hover:border-emerald-600">
                    Launch Portal
                </a>
            </div>
        </nav>

        <!-- Hero Content -->
        <main class="relative z-10 w-full max-w-7xl px-8 flex flex-col items-center text-center mt-48 mx-auto flex-1">
            <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full bg-emerald-950/40 border border-emerald-900/50 mb-10 animate-fade-in-up">
                <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_#10b981] animate-pulse"></span>
                <span class="text-[10px] font-black text-emerald-400 uppercase tracking-[0.2em] leading-none">Academic Portal</span>
            </div>

            <h1 class="text-6xl md:text-9xl font-black font-headline tracking-tighter leading-[0.85] hero-title max-w-5xl mb-12">
                Project Approval <br/> 
                <span class="text-emerald-500 text-glow-emerald">Simplified.</span>
            </h1>

            <p class="text-lg md:text-xl text-slate-400 font-medium max-w-2xl leading-relaxed mb-16 animate-fade-in-up" style="animation-delay: 0.1s;">
                A centralized infrastructure for students to submit project proposals, receive faculty approvals, and connect with expert supervisors through a merit-based workflow.
            </p>

            <div class="flex flex-col sm:flex-row items-center gap-6 animate-fade-in-up mb-32" style="animation-delay: 0.2s;">
                <a href="@Url.Action("Login", "Account")" class="btn-premium bg-emerald-600 hover:bg-emerald-500 text-white font-black text-lg px-14 py-6 rounded-2xl shadow-[0_20px_40px_-10px_rgba(16,185,129,0.3)] transition-all font-headline">
                    Access System
                </a>
            </div>

            <!-- Workflow Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mt-48 w-full">
                <div class="premium-card p-12 rounded-[3.5rem] text-left">
                    <div class="w-16 h-16 rounded-2xl bg-emerald-950/50 text-emerald-500 flex items-center justify-center mb-10 border border-emerald-900/30">
                        <span class="material-symbols-outlined text-3xl">add_task</span>
                    </div>
                    <h3 class="text-2xl font-bold text-white font-headline mb-4">Proposal Submission</h3>
                    <p class="text-slate-400 font-medium leading-relaxed">Students submit detailed project proposals for evaluation by academic coordinators.</p>
                </div>

                <div class="premium-card p-12 rounded-[3.5rem] text-left border-emerald-900/30 bg-emerald-950/10">
                    <div class="w-16 h-16 rounded-2xl bg-emerald-600 text-white flex items-center justify-center mb-10 shadow-[0_10px_30px_rgba(16,185,129,0.3)]">
                        <span class="material-symbols-outlined text-3xl font-bold">assignment_turned_in</span>
                    </div>
                    <h3 class="text-2xl font-bold text-white font-headline mb-4">Faculty Approval</h3>
                    <p class="text-slate-400 font-medium leading-relaxed">A streamlined workflow for faculty members to review, approve, and finalize project requests.</p>
                </div>

                <div class="premium-card p-12 rounded-[3.5rem] text-left">
                    <div class="w-16 h-16 rounded-2xl bg-emerald-950/50 text-emerald-500 flex items-center justify-center mb-10 border border-emerald-900/30">
                        <span class="material-symbols-outlined text-3xl">supervisor_account</span>
                    </div>
                    <h3 class="text-2xl font-bold text-white font-headline mb-4">Supervisor Tracking</h3>
                    <p class="text-slate-400 font-medium leading-relaxed">Module leaders can monitor student-supervisor links and audit the entire supervision lifecycle.</p>
                </div>
            </div>
        </main>

        <footer class="w-full py-12 mt-32 glass-nav relative z-10 border-t border-white/5">
            <div class="max-w-7xl mx-auto px-8 flex flex-col md:flex-row items-center justify-between">
                <div class="flex items-center gap-3 opacity-50 mb-6 md:mb-0">
                    <div class="w-8 h-8 rounded-lg bg-slate-800 flex items-center justify-center">
                        <span class="material-symbols-outlined text-sm">hub</span>
                    </div>
                    <span class="text-[10px] font-black tracking-tighter uppercase">UniSync Project Portal</span>
                </div>
                <div class="text-[9px] font-black uppercase tracking-[0.4em] text-slate-600">© 2026 University Approval System • Group U</div>
            </div>
        </footer>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const elements = document.querySelectorAll('.animate-fade-in-up');
            elements.forEach((el) => {
                el.style.opacity = '0';
                el.style.transform = 'translateY(20px)';
                el.style.transition = `all 1.2s cubic-bezier(0.16, 1, 0.3, 1) ${el.style.animationDelay || '0s'}`;
                
                setTimeout(() => {
                    el.style.opacity = '1';
                    el.style.transform = 'translateY(0)';
                }, 100);
            });

            // Navigation Visual Protocol
            const nav = document.querySelector('nav');
            window.addEventListener('scroll', () => {
                if (window.scrollY > 50) {
                    nav.style.background = 'rgba(2, 6, 23, 0.85)';
                    nav.style.backdropFilter = 'blur(16px)';
                    nav.style.borderBottomColor = 'rgba(255, 255, 255, 0.08)';
                } else {
                    nav.style.background = 'rgba(2, 6, 23, 0.4)';
                    nav.style.backdropFilter = 'blur(12px)';
                    nav.style.borderBottomColor = 'rgba(255, 255, 255, 0.03)';
                }
            });
        });
    </script>
</body>
</html>
